{
  "name": "photo-layout-studio",
  "productName": "奇妙奇遇光影集 - 排版 Studio",
  "version": "1.2.0",
  "description": "专业照片排版工具，完全离线运行",
  "main": "electron/main.js",
  "author": "奇妙奇遇",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:vite": "cd web && pnpm dev",
    "dev:electron": "NODE_ENV=development electron .",
    "build:web": "cd web && pnpm build",
    "build:win": "npm run build:web && electron-builder --win --config.publish=null",
    "build:mac": "npm run build:web && electron-builder --mac --config.publish=null",
    "build:linux": "npm run build:web && electron-builder --linux AppImage --config.publish=null",
    "pack": "electron-builder --dir --config.publish=null"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.qimiao.photo-layout-studio",
    "publish": [],
    "productName": "光影集排版Studio",
    "copyright": "Copyright © 2024 奇妙奇遇",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "光影集排版Studio"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.graphics-design",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "光影集排版Studio",
      "icon": "assets/icon.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Graphics"
    }
  }
}
